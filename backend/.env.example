# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY

# S3 Bucket for exports
S3_BUCKET_NAME=subscription-simulator-exports-dev

# DynamoDB Tables
DYNAMO_SCENARIOS_TABLE=subscription-simulator-scenarios-dev
DYNAMO_SESSIONS_TABLE=subscription-simulator-sessions-dev

# CloudWatch
CLOUDWATCH_LOG_GROUP=/subscription-simulator/api-dev

# Application
NODE_ENV=development
PORT=3001
JWT_SECRET=your-jwt-secret-key
DATABASE_URL=./data/simulator.db
